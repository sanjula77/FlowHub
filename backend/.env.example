# ── FlowHub Backend — Environment Variables ───────────────────────────────────
# Copy this file to .env for local development.
# In Choreo, set these via: Component → DevOps → Configs & Secrets
# DB_* variables are injected automatically when you link a Choreo-managed
# PostgreSQL database to this component — no need to set them manually there.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5435
DB_USER=flowhub
DB_PASSWORD=flowhub
DB_NAME=flowhub_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Choreo frontend URL in production
FRONTEND_URL=http://localhost:3000

# ── Node ──────────────────────────────────────────────────────────────────────
# Set to "production" in Choreo to disable TypeORM synchronize
NODE_ENV=development

# ── Admin seed (optional) ─────────────────────────────────────────────────────
# If set, BootstrapService creates this admin account on first startup.
# Leave blank to skip auto-seeding.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
# Choreo injects PORT automatically — only needed for local overrides
# PORT=3001
